<!DOCTYPE html>
<html>
  <head>
    <title>My Daily Favorites</title>
    <style>
      table {
        width: 100%;
        font-family: Helvetica;
      }

      .header {
        background-color: OliveDrab;
        color: white;
        text-align: center;
      }

      .odd-row {
        background-color: SandyBrown;
      }

      .even-row {
        background-color: LightCoral;
      }

      td, th {
        padding: 10px;
      }
    </style>
  </head>
  <body>
    <h1>My Daily Favorites</h1>
    <table border="1">
      <tr class="header">
        <th>Sunday</th>
        <th>Monday</th>
        <th>Tuesday</th>
        <th>Wednesday</th>
        <th>Thursday</th>
        <th>Friday</th>
        <th>Saturday</th>
      </tr>
      <tr class="odd-row">
        <td>Pancakes</td>
        <td>Toast and Peanut Butter</td>
        <td>Protein Shake</td>
        <td>Toast and Peanut Butter</td>
        <td>Eggs and Bacon</td>
        <td>Cereal</td>
        <td>Waffles</td>
      </tr>
      <tr class="even-row">
        <td>Go to the lake</td>
        <td>Play soccer</td>
        <td>Play board games</td>
        <td>Watch TV</td>
        <td>Go hiking</td>
        <td>Play video games</td>
        <td>Go swimming</td>
      </tr>
      <tr class="odd-row">
        <td>Parents</td>
        <td>Janice</td>
        <td>Janice</td>
        <td>Janice</td>
        <td>Parents</td>
        <td>Friends</td>
        <td>Family</td>
      </tr>
      <tr class="even-row">
        <td>Art Museum</td>
        <td>Park</td>
        <td>Game store</td>
        <td>Living room</td>
        <td>Backyard</td>
        <td>Mall</td>
        <td>Beach</td>
      </tr>
    </table>
  </body>
</html>
