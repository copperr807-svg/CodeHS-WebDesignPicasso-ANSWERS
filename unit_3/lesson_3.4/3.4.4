<!DOCTYPE html>
<html>
    <head>
        <title>Important Things</title>
        <style>
            #important {
                color: red;
                font-size: 20px;
            }
            #second {
                color: orange;
            }
            #third {
                color: gold;
            }
        </style>
    </head>
